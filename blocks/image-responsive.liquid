{% doc %}
  Renders a responsive image that shows one image on mobile and a different one on desktop.
  Uses the <picture> element so the browser only downloads the appropriate image per viewport,
  improving page speed (smaller payload on mobile, no duplicate downloads).

  @example
  {% content_for 'block', type: 'responsive-image', id: 'responsive-image' %}
{% enddoc %}

{%- liquid
  assign mobile_image = block.settings.mobile_image
  assign desktop_image = block.settings.desktop_image
-%}

<div
  class="responsive-image-block spacing-style{% unless block.settings.full_width_mobile %} responsive-image-block--constrained-mobile{% endunless %}{% unless block.settings.full_width_desktop %} responsive-image-block--constrained-desktop{% endunless %}"
  style="
    {%- if mobile_image != blank and mobile_image.presentation.focal_point -%}
      --responsive-image-focal-point-mobile: {{ mobile_image.presentation.focal_point }};
    {%- elsif desktop_image != blank and desktop_image.presentation.focal_point -%}
      --responsive-image-focal-point-mobile: {{ desktop_image.presentation.focal_point }};
    {%- endif -%}
    {%- if desktop_image != blank and desktop_image.presentation.focal_point -%}
      --responsive-image-focal-point-desktop: {{ desktop_image.presentation.focal_point }};
    {%- elsif mobile_image != blank and mobile_image.presentation.focal_point -%}
      --responsive-image-focal-point-desktop: {{ mobile_image.presentation.focal_point }};
    {%- endif -%}
    {%- render 'spacing-style', settings: block.settings -%}
    {%- unless block.settings.full_width_mobile -%}
      --responsive-image-max-width-mobile: {{ block.settings.max_width_mobile }}px;
    {%- endunless -%}
    {%- unless block.settings.full_width_desktop -%}
      --responsive-image-max-width-desktop: {{ block.settings.max_width_desktop }}px;
    {%- endunless -%}
  "
  {{ block.shopify_attributes }}
>
  {%- render 'responsive-picture',
    mobile_image: mobile_image,
    desktop_image: desktop_image,
    image_class: 'responsive-image-block__image',
    loading: 'lazy',
    fetch_priority: 'auto',
    picture_class: 'responsive-image-block__picture',
    placeholder: 'image',
    placeholder_class: 'placeholder-svg placeholder-svg--fill responsive-image-block__image'
  -%}
</div>

{% stylesheet %}
  .responsive-image-block {
    width: 100%;
  }
  .responsive-image-block--constrained-mobile {
    max-width: var(--responsive-image-max-width-mobile);
    margin-left: auto;
    margin-right: auto;
  }
  @media (min-width: 768px) {
    .responsive-image-block--constrained-mobile {
      max-width: none;
    }
    .responsive-image-block--constrained-desktop {
      max-width: var(--responsive-image-max-width-desktop);
      margin-left: auto;
      margin-right: auto;
    }
  }
  .responsive-image-block__picture {
    display: block;
    width: 100%;
  }
  .responsive-image-block__image {
    display: block;
    height: auto;
    object-position: var(--responsive-image-focal-point-mobile, center);
    width: 100%;
  }
  @media (min-width: 768px) {
    .responsive-image-block__image {
      object-position: var(--responsive-image-focal-point-desktop, var(--responsive-image-focal-point-mobile, center));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.image_responsive",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:settings.mobile_image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "t:settings.mobile_image"
    },
    {
      "type": "checkbox",
      "id": "full_width_mobile",
      "label": "t:settings.full_width",
      "default": true
    },
    {
      "type": "number",
      "id": "max_width_mobile",
      "label": "t:settings.max_width",
      "info": "t:info.max_width",
      "visible_if": "{{ block.settings.full_width_mobile == false }}"
    },
    {
      "type": "header",
      "content": "t:settings.desktop_image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "t:settings.desktop_image"
    },
    {
      "type": "checkbox",
      "id": "full_width_desktop",
      "label": "t:settings.full_width",
      "default": true
    },
    {
      "type": "number",
      "id": "max_width_desktop",
      "label": "t:settings.max_width",
      "info": "t:info.max_width",
      "visible_if": "{{ block.settings.full_width_desktop == false }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.image_responsive"
    }
  ]
}
{% endschema %}
