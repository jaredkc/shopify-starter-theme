{% comment %}
  For sticky-header to work, we need to target the wrapper around this Shopify section.
  The schema enforces `.section-sticky-header` on the wrapper around this component.
  Keep this lookup in sync with `assets/global.js` to avoid breaking sticky behaviour.
{% endcomment %}
{% render 'search-dialog-modal' %}
<sticky-header>
  <header class="flex justify-between items-center px-4 py-2 text-center border-b md:py-4 md:px-8">
    {%- if template.name == 'index' -%}
      <h1 class="m-0 text-base" itemscope itemtype="http://schema.org/Organization">
    {%- else -%}
      <div class="m-0 text-base" itemscope itemtype="http://schema.org/Organization">
    {%- endif -%}
    <a href="{{ routes.root_url }}" itemprop="url" class="site-header__logo">{{ shop.name }}</a>
    {%- if template.name == 'index' -%}</h1>{%- else -%}</div>{%- endif -%}

    {%- if section.settings.menu != blank -%}
      <nav id="site-navigation" class="site-navigation">
        <ul class="nav-menu">
          {%- for link in section.settings.menu.links -%}
            {%- assign child_list_handle = link.title | handleize -%}
            {%- if linklists[child_list_handle].links != blank -%}
              <li>
                <a href="{{ link.url }}" class="whitespace-nowrap">{{ link.title }}</a>
                <ul class="nav-submemu">
                  {%- for childlink in linklists[child_list_handle].links -%}
                    <li>
                      <a href="{{ childlink.url }}" class="whitespace-nowrap">{{ childlink.title | escape }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              </li>
            {%- else -%}
              <li>
                <a href="{{ link.url }}" class="whitespace-nowrap">{{ link.title }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    <nav class="flex gap-4 items-center">
      <dialog-opener data-dialog="#search-dialog">
        <button class="btn-link flex items-center">
          <span class="sr-only">Open Search</span>
          {{- 'icon-search.svg' | inline_asset_content -}}
        </button>
      </dialog-opener>
      {%- if shop.customer_accounts_enabled -%}
        <div>
          {% comment %}
            Using {{- 'icon-user.svg' | inline_asset_content -}}
            in the <shopify-account> componet does not work 🤷‍♂️
          {% endcomment %}
          <shopify-account menu="{{ section.settings.customer_account_menu }}">
            <span slot="signed-out-avatar">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="24"
                height="24"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
              >
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
              <span class="sr-only">{{- 'customer.log_in' | t -}}</span>
            </span>
          </shopify-account>
        </div>
      {%- endif -%}
      <a href="{{ routes.cart_url }}">
        {{- 'icon-cart.svg' | inline_asset_content -}}
        <span class="sr-only">{{- 'templates.cart.cart' | t -}}</span>
      </a>
    </nav>
  </header>
</sticky-header>

<script src="{{ 'header.js' | asset_url }}" defer="defer"></script>

{% stylesheet %}
  .section-sticky-header {
    --bg-color: #fff;
    background-color: var(--bg-color);
    top: 0;
    isolation: isolate;
    z-index: 100;
  }

  .sticky-header-hidden,
  .sticky-header-stuck {
    position: sticky;
    will-change: transform;
    transition: all var(--duration-medium) ease-out;
  }

  .sticky-header-hidden {
    transform: translateY(-100%);
    box-shadow: none;
  }

  .sticky-header-stuck {
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    transform: translateY(0);
  }

  .nav-menu > li {
    display: inline-block;
    margin-left: 1rem;
    margin-right: 1rem;
    position: relative;
  }

  .nav-submemu {
    background: var(--bg-color);
    display: none;
    left: 0;
    list-style-type: none;
    padding: 0.5rem 0;
    position: absolute;
    text-align-last: left;
    top: 100%;
    z-index: 1;
  }

  .nav-submemu a {
    display: block;
    padding: 0.5rem 0.7rem;
  }

  .nav-menu > li:hover .nav-submemu {
    display: block;
    z-index: 100;
  }
{% endstylesheet %}

<style>
  /* See available variables here: https://shopify.dev/docs/api/storefront-web-components/components/shopify-account */
  shopify-account {
    --shopify-account-color-accent: var(--c-primary-medium);
    --shopify-account-radius-base: 0;
    --shopify-account-signed-in-avatar-size: 24px;
  }
</style>

{% comment %}
  <script>
    // The --shop-brand-color is not available to override,
    // so if it is desired to change this JavaScript is needed. Lame!
    setTimeout(() => {
      const host = document.querySelector('shopify-account');

      if (host && host.shadowRoot) {
        const element = host.shadowRoot.querySelector('#shopify-element-wrapper');
        if (element) {
          element.style.setProperty('--shop-brand-color', '#ff0000');
        }
      } else {
        console.error('Shadow host <shopify-account> not found or its shadowRoot is closed.');
      }
    }, 250);
  </script>
{% endcomment %}

{% schema %}
{
  "name": "Header",
  "class": "section-sticky-header sticky-header-stuck",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "default": "customer-account-main-menu",
      "label": "t:settings.customer_account_menu"
    }
  ]
}
{% endschema %}
