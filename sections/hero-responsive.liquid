{% liquid
  assign mobile_image = section.settings.mobile_image
  assign desktop_image = section.settings.desktop_image

  assign fetch_priority = 'auto'
  assign loading = 'lazy'
  if section.index == 1
    assign fetch_priority = 'high'
    assign loading = 'eager'
  endif
-%}

{%- comment -%}
  Focal point via CSS vars per breakpoint; manual img so image_tag's
  inline object-position doesn't override and break the desktop crop.
{%- endcomment -%}

<div
  id="hero-responsive-{{ section.id }}"
  class="hero-responsive color-{{ section.settings.color_scheme }}"
  style="
    {% if mobile_image != blank %}
      --mobile-aspect: {{ mobile_image.aspect_ratio }};
      --mobile-focal-point: {{ mobile_image.presentation.focal_point }};
    {% endif %}
    {% if section.settings.mobile_section_height == 'custom' %}
      --mobile-min-height: {{ section.settings.mobile_section_height_custom }}px;
    {% elsif section.settings.mobile_section_height == 'full-screen' %}
      --mobile-min-height: 100svh;
    {% endif %}

    {% if desktop_image != blank %}
      --aspect-desktop: {{ desktop_image.aspect_ratio }};
      --focal-point-desktop: {{ desktop_image.presentation.focal_point }};
    {% endif %}
    {% if section.settings.section_height == 'custom' %}
      --min-height: {{ section.settings.section_height_custom }}px;
    {% elsif section.settings.section_height == 'full-screen' %}
      --min-height: 100svh;
    {% endif %}
  "
>
  <div class="hero-responsive__media" aria-hidden="true">
    {% render 'responsive-picture',
      mobile_image: mobile_image,
      desktop_image: desktop_image,
      image_class: 'hero-responsive__media-image',
      loading: loading,
      fetch_priority: fetch_priority,
      picture_class: 'hero-responsive__picture',
      placeholder: 'hero-apparel-1',
      placeholder_class: 'hero-responsive__placeholder'
    %}
  </div>

  <div class="hero-responsive__inner {{ section.settings.section_width }}">
    <div
      class="hero-responsive__content spacing-style"
      style="
        --mobile-gap: {{ section.settings.mobile_gap }}px;
        --mobile-justify: {{ section.settings.mobile_column_position }};
        --mobile-align: {{ section.settings.mobile_column_alignment }};
        --desktop-direction: {{ section.settings.content_direction }};
        --desktop-gap: {{ section.settings.gap }}px;
        {% if section.settings.content_direction == 'row' %}
          --desktop-justify: {{ section.settings.row_alignment }};
          --desktop-align: {{ section.settings.row_position }};
        {% else %}
          --desktop-justify: {{ section.settings.column_position }};
          --desktop-align: {{ section.settings.column_alignment }};
        {% endif %}
        {% render 'spacing-style', settings: section.settings %}
      "
    >
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% stylesheet %}
  .hero-responsive {
    aspect-ratio: var(--mobile-aspect, 5 / 4);
    min-height: var(--mobile-min-height);
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .hero-responsive__media {
    inset: 0;
    position: absolute;
    z-index: 0;
  }

  .hero-responsive__inner {
    display: flex;
    inset: 0;
    position: absolute;
    z-index: 1;
  }

  .hero-responsive__picture {
    display: block;
    height: 100%;
    width: 100%;
  }

  .hero-responsive__media-image {
    display: block;
    height: 100%;
    object-fit: cover;
    object-position: var(--mobile-focal-point, center);
    width: 100%;
  }

  .hero-responsive__placeholder {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .hero-responsive__content {
    align-items: var(--mobile-align);
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--mobile-gap);
    justify-content: var(--mobile-justify);
    min-width: 0;
    position: relative;
  }
  [style*='--mobile-align: flex-start'] > .text-block {
    --text-align-default: left;
  }
  [style*='--mobile-align: center'] > .text-block {
    --text-align-default: center;
  }
  [style*='--mobile-align: flex-end'] > .text-block {
    --text-align-default: right;
  }

  @media (min-width: 768px) {
    .hero-responsive {
      aspect-ratio: var(--aspect-desktop, 16 / 9);
      min-height: var(--min-height);
    }

    .hero-responsive__media-image {
      object-position: var(--focal-point-desktop, center);
    }

    .hero-responsive__content {
      align-items: var(--desktop-align);
      flex-direction: var(--desktop-direction);
      gap: var(--desktop-gap);
      justify-content: var(--desktop-justify);
    }
    [style*='--desktop-align: flex-start'] > .text-block {
      --text-align-default: left;
    }
    [style*='--desktop-align: center'] > .text-block {
      --text-align-default: center;
    }
    [style*='--desktop-align: flex-end'] > .text-block {
      --text-align-default: right;
    }
  }
{% endstylesheet %}

