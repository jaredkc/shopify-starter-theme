{%- liquid
  assign mobile_image = section.settings.mobile_image
  assign desktop_image = section.settings.desktop_image

  assign fetch_priority = 'auto'
  assign loading = 'lazy'
  if section.index == 1
    assign fetch_priority = 'high'
    assign loading = 'eager'
  endif
-%}

{%- comment -%}
  Focal point via CSS vars per breakpoint; manual img so image_tag's
  inline object-position doesn't override and break the desktop crop.
{%- endcomment -%}

<div
  id="hero-responsive-{{ section.id }}"
  class="hero-responsive color-{{ section.settings.color_scheme }}"
  style="
    {%- if mobile_image != blank and mobile_image.width and mobile_image.height -%}
      --hero-aspect-mobile: {{ mobile_image.width }} / {{ mobile_image.height }};
    {%- endif -%}
    {%- if desktop_image != blank and desktop_image.width and desktop_image.height -%}
      --hero-aspect-desktop: {{ desktop_image.width }} / {{ desktop_image.height }};
    {%- endif -%}
    {%- if mobile_image != blank and mobile_image.presentation.focal_point -%}
      --hero-focal-point-mobile: {{ mobile_image.presentation.focal_point }};
    {%- elsif desktop_image != blank and desktop_image.presentation.focal_point -%}
      --hero-focal-point-mobile: {{ desktop_image.presentation.focal_point }};
    {%- endif -%}
    {%- if desktop_image != blank and desktop_image.presentation.focal_point -%}
      --hero-focal-point-desktop: {{ desktop_image.presentation.focal_point }};
    {%- elsif mobile_image != blank and mobile_image.presentation.focal_point -%}
      --hero-focal-point-desktop: {{ mobile_image.presentation.focal_point }};
    {%- endif -%}
  "
>
  <div class="hero-responsive__media" aria-hidden="true">
    {%- if mobile_image != blank or desktop_image != blank -%}
      <picture class="hero-responsive__picture">
        {%- if desktop_image != blank -%}
          <source
            media="(min-width: 768px)"
            sizes="100vw"
            srcset="{{ desktop_image | image_url: width: 768 }} 768w, {{ desktop_image | image_url: width: 1200 }} 1200w, {{ desktop_image | image_url: width: 1920 }} 1920w, {{ desktop_image | image_url: width: 3840 }} 3840w"
          >
        {%- endif -%}

        {%- if mobile_image != blank -%}
          <img
            class="hero-responsive__media-image"
            src="{{ mobile_image | image_url: width: 1200 }}"
            srcset="{{ mobile_image | image_url: width: 375 }} 375w, {{ mobile_image | image_url: width: 550 }} 550w, {{ mobile_image | image_url: width: 768 }} 768w, {{ mobile_image | image_url: width: 1200 }} 1200w"
            sizes="100vw"
            decoding="async"
            loading="{{ loading }}"
            fetchpriority="{{ fetch_priority }}"
            alt="{{ mobile_image.alt | escape }}"
            width="{{ mobile_image.width }}"
            height="{{ mobile_image.height }}"
          >
        {%- elsif desktop_image != blank -%}
          <img
            class="hero-responsive__media-image"
            src="{{ desktop_image | image_url: width: 1200 }}"
            srcset="{{ desktop_image | image_url: width: 375 }} 375w, {{ desktop_image | image_url: width: 550 }} 550w, {{ desktop_image | image_url: width: 768 }} 768w, {{ desktop_image | image_url: width: 1200 }} 1200w"
            sizes="100vw"
            decoding="async"
            loading="{{ loading }}"
            fetchpriority="{{ fetch_priority }}"
            alt="{{ desktop_image.alt | escape }}"
            width="{{ desktop_image.width }}"
            height="{{ desktop_image.height }}"
          >
        {%- endif -%}
      </picture>
    {%- else -%}
      {{- 'hero-apparel-1' | placeholder_svg_tag: 'hero-responsive__placeholder' -}}
    {%- endif -%}
  </div>

  <div class="{{ section.settings.section_width }}">
    <div
      class="hero-responsive__content spacing-style"
      style="
        --gap: {{ section.settings.gap }}px;
        --gap-mobile: {{ section.settings.gap_mobile }}px;
        --mobile-justify: {{ section.settings.column_position_mobile }};
        --mobile-align: {{ section.settings.column_alignment_mobile }};
        --desktop-direction: {{ section.settings.content_direction }};
        {%- if section.settings.content_direction == 'row' -%}
          --desktop-justify: {{ section.settings.row_alignment }};
          --desktop-align: {{ section.settings.row_position }};
        {%- else -%}
          --desktop-justify: {{ section.settings.column_position }};
          --desktop-align: {{ section.settings.column_alignment }};
        {%- endif -%}
        {%- render 'spacing-style', settings: section.settings -%}
      "
    >
      {%- content_for 'blocks' -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .hero-responsive {
    overflow: hidden;
    position: relative;
  }

  .hero-responsive__media {
    inset: 0;
    position: absolute;
    z-index: 0;
  }

  .hero-responsive__picture {
    display: block;
    height: 100%;
    width: 100%;
  }

  .hero-responsive__media-image {
    display: block;
    height: 100%;
    object-fit: cover;
    object-position: var(--hero-focal-point-mobile, center);
    width: 100%;
  }

  .hero-responsive__placeholder {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .hero-responsive__content {
    align-items: var(--mobile-align);
    aspect-ratio: var(--hero-aspect-mobile, 5 / 4);
    display: flex;
    flex-direction: column;
    gap: var(--gap-mobile);
    justify-content: var(--mobile-justify);
    max-height: 100dvh;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .hero-responsive__media-image {
      object-position: var(--hero-focal-point-desktop, var(--hero-focal-point-mobile, center));
    }

    .hero-responsive__content {
      align-items: var(--desktop-align);
      aspect-ratio: var(--hero-aspect-desktop, 16 / 9);
      flex-direction: var(--desktop-direction);
      gap: var(--gap);
      justify-content: var(--desktop-justify);
    }
  }
{% endstylesheet %}

